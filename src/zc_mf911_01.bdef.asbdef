projection;
strict ( 2 );
use draft;
use side effects;

define behavior for ZC_MF911_01 alias Header
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Item { create; with draft; }
}

define behavior for ZC_MF911_02 alias Item
{
  use association _header { with draft; }
}
